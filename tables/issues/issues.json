{
  "name": "issues",
  "primary_key_column": "id",
  "enable_rls": false,
  "columns": [
    {
      "name": "repository_id",
      "type": "UUID",
      "required": true,
      "foreign_key": {
        "references": "repositories.id"
      }
    },
    {
      "name": "gh_issue_id",
      "type": "INTEGER",
      "required": true
    },
    {
      "name": "title",
      "type": "TEXT",
      "required": true
    },
    {
      "name": "description",
      "type": "TEXT",
      "required": false
    },
    {
      "name": "labels",
      "type": "JSON",
      "required": false
    },
    {
      "name": "difficulty_score",
      "type": "INTEGER",
      "required": false
    },
    {
      "name": "is_beginner_friendly",
      "type": "BOOLEAN",
      "required": false,
      "default": false
    },
    {
      "name": "suggested_skills",
      "type": "JSON",
      "required": false
    },
    {
      "name": "estimated_hours",
      "type": "INTEGER",
      "required": false
    },
    {
      "name": "status",
      "type": "ENUM",
      "required": false,
      "default": "open",
      "options": ["open", "assigned", "completed"]
    },
    {
      "name": "assigned_to_user_id",
      "type": "UUID",
      "required": false
    },
    {
      "name": "gh_url",
      "type": "TEXT",
      "required": false
    }
  ],
  "config": {}
}
