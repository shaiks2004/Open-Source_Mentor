{
  "name": "contribution-tracker",
  "description": "Monitors pull requests, commits, and completed tasks to update developer contribution logs and profiles.",
  "instruction": {
    "$file": "instruction.md"
  },
  "toolsets": [
    "POD",
    "WORKSPACE_CLI"
  ],
  "visibility": "POD",
  "agent_runtime": {
    "profile_id": "system:lemma",
    "model_name": "deepseek-v4-pro"
  },
  "permissions": {
    "grants": [
      {
        "resource_type": "datastore_table",
        "resource_name": "issues",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "knowledge",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "learning_modules",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "progress",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "pull_requests",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "repositories",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "reviews",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
        "resource_type": "datastore_table",
        "resource_name": "tasks",
        "permission_ids": [
          "datastore.table.read",
          "datastore.record.read",
          "datastore.record.write"
        ]
      },
      {
